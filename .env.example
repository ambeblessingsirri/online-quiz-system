# ─── Application ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost

# ─── Database (MongoDB Atlas) ──────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/quizsystem?retryWrites=true&w=majority

# ─── Authentication ────────────────────────────────────────────
JWT_SECRET=replace_with_a_very_long_random_secret_string_min_32_chars
JWT_EXPIRES_IN=24h

# ─── AI (Anthropic Claude API) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-replace-with-your-key

# ─── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
