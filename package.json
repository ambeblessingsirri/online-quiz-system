{
  "name": "online-quiz-system",
  "version": "1.0.0",
  "description": "AI-Powered Online Quiz & Practice System",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "lint": "eslint backend/**/*.js --fix",
    "lint:check": "eslint backend/**/*.js",
    "format": "prettier --write \"backend/**/*.js\" \"frontend/**/*.{html,css,js}\"",
    "format:check": "prettier --check \"backend/**/*.js\" \"frontend/**/*.{html,css,js}\"",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "socket.io": "^4.6.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["backend/**/*.js", "!backend/server.js"],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "clover"]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "AMBE BLESSING SIRRI",
  "license": "MIT"
}
